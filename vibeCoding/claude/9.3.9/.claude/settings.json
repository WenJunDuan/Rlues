{
  "environmentVariables": {
    "VIBECODING_VERSION": "9.3.9",
    "LANGUAGE": "zh-Hans",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": 1,
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": 1,
    "CLAUDE_CODE_DISABLE_FEEDBACK_SURVEY": 1,
    "NEXT_TELEMETRY_DISABLED": 1,
    "NUXT_TELEMETRY_DISABLED": 1,
    "GATSBY_TELEMETRY_DISABLED": 1,
    "ASTRO_TELEMETRY_DISABLED": 1,
    "ANGULAR_CLI_ANALYTICS": false,
    "ENABLE_TOOL_SEARCH": "true",
    "API_TIMEOUT_MS": 3000000
  },
  "includeCoAuthoredBy": false,
  "effortLevel": "high",
  "permissions": {
    "allow": [
      "Bash(npm test *)",
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git worktree *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(echo *)",
      "Bash(which *)",
      "Bash(pwd)",
      "Bash(cd *)",
      "Bash(codex *)",
      "Bash(npx ctx7 *)",
      "Bash(ctx7 *)",
      "Bash(npx ecc-agentshield *)",
      "Bash(npx prettier *)",
      "Bash(npx eslint *)",
      "Bash(npx tsc *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf /*)",
      "Bash(> /dev/sda*)",
      "Bash(mkfs.*)",
      "Bash(dd if=*)",
      "Bash(chmod -R 777 /)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)",
      "Bash(git push * --force)",
      "Bash(git push origin main)",
      "Bash(git push origin master)",
      "Read(./.env.production)",
      "Read(./.env.local)",
      "Read(./secrets/**)",
      "Read(./**/credentials*)",
      "Read(./**/*.pem)",
      "Read(./**/*.key)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(rm *)",
            "command": "test -f \"$HOME/.claude/hooks/pre-bash-guard.cjs\" && node \"$HOME/.claude/hooks/pre-bash-guard.cjs\" || true"
          },
          {
            "type": "command",
            "if": "Bash(git push *)",
            "command": "test -f \"$HOME/.claude/hooks/pre-bash-guard.cjs\" && node \"$HOME/.claude/hooks/pre-bash-guard.cjs\" || true"
          },
          {
            "type": "command",
            "if": "Bash(curl *)",
            "command": "test -f \"$HOME/.claude/hooks/pre-bash-guard.cjs\" && node \"$HOME/.claude/hooks/pre-bash-guard.cjs\" || true"
          },
          {
            "type": "command",
            "if": "Bash(wget *)",
            "command": "test -f \"$HOME/.claude/hooks/pre-bash-guard.cjs\" && node \"$HOME/.claude/hooks/pre-bash-guard.cjs\" || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "审查 assistant 回复: 1) 用户需求完整解决? 2) 有无遗漏边界? 3) 有 TODO 占位符? 纯 JSON: {\"decision\":\"approve\"} 或 {\"decision\":\"reject\",\"reason\":\"...\"}",
            "timeout": 20
          },
          {
            "type": "command",
            "command": "test -f \"$HOME/.claude/hooks/delivery-gate.cjs\" && node \"$HOME/.claude/hooks/delivery-gate.cjs\" || true"
          }
        ]
      }
    ],
    "PermissionDenied": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "test -f \"$HOME/.claude/hooks/permission-retry.cjs\" && node \"$HOME/.claude/hooks/permission-retry.cjs\" || true"
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "cunzhi": {
      "command": "寸止",
      "disabled": false
    },
    "augment-context-engine": {
      "command": "npx",
      "args": [
        "ace-tool-rs",
        "--base-url",
        "https://acemcp.heroman.wtf/relay/",
        "--token",
        ""
      ],
      "disabled": false
    }
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": { "source": "github", "repo": "obra/superpowers-marketplace" }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "openai-codex": {
      "source": { "source": "github", "repo": "openai/codex-plugin-cc" }
    },
    "playwright-skill": {
      "source": { "source": "github", "repo": "lackeyjb/playwright-skill" }
    },
    "context7-marketplace": {
      "source": { "source": "github", "repo": "upstash/context7" }
    }
  },
  "enabledPlugins": {
    "superpowers@superpowers-marketplace": true,
    "everything-claude-code@everything-claude-code": true,
    "codex@openai-codex": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "playwright-skill@playwright-skill": true,
    "context7-plugin@context7-marketplace": true
  }
}
