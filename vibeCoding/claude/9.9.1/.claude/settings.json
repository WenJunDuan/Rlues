{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "best",
  "effortLevel": "xhigh",
  "fallbackModel": [
    "opus",
    "sonnet"
  ],
  "worktree": {
    "baseRef": "head"
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "env": {
    "VIBECODING_ATHENA_VERSION": "9.9.1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "CLAUDE_CODE_ATTRIBUTION_HEADER": "0"
  },
  "permissions": {
    "defaultMode": "default",
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git show*)",
      "Bash(git branch --show-current)",
      "Bash(git rev-parse*)",
      "Bash(npm test*)",
      "Bash(npm run test*)",
      "Bash(npm run build*)",
      "Bash(npm run lint*)",
      "Bash(pnpm test*)",
      "Bash(pnpm run test*)",
      "Bash(pnpm run build*)",
      "Bash(pnpm run lint*)",
      "Bash(yarn test*)",
      "Bash(bun test*)",
      "Bash(npx playwright*)",
      "Bash(npx ecc-agentshield*)",
      "Bash(node --check*)",
      "Bash(python3 -m pytest*)",
      "Bash(python3 -m unittest*)",
      "Bash(pytest*)",
      "Bash(rg *)",
      "Bash(ls *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(jq *)",
      "Bash(cmake --build*)",
      "Bash(./gradlew test*)",
      "Bash(./gradlew build*)",
      "Bash(mvn test*)",
      "Bash(mvn compile*)",
      "Bash(cargo test*)",
      "Bash(cargo build*)",
      "Bash(go test*)",
      "Bash(go build*)",
      "Bash(eslint *)",
      "Bash(prettier --check*)",
      "Bash(tsc --noEmit*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gcloud/**)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials.json)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME*)",
      "Bash(git push *--force*)",
      "Bash(npm publish*)",
      "Bash(pnpm publish*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/session-start.cjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/pre-bash-guard.cjs",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/subagent-worktree-check.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/index-updater.cjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/evidence-collector.cjs",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/design-change-detector.cjs",
            "timeout": 5,
            "if": "Edit(**/design.md)"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/evidence-collector.cjs",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/evidence-collector.cjs",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/subagent-retry.cjs",
            "timeout": 10
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/subagent-tracker.cjs",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/token-usage-collector.cjs",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/subagent-tracker.cjs",
            "timeout": 15
          }
        ]
      }
    ],
    "InstructionsLoaded": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/config-change-audit.cjs",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "ConfigChange": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/config-change-audit.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/token-usage-collector.cjs",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/delivery-gate.cjs",
            "timeout": 60
          },
          {
            "type": "command",
            "command": "node ~/.claude/hooks/pace-continuator.cjs",
            "timeout": 30
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/stop-failure-recorder.cjs",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/compact-snapshot.cjs",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/compact-restore.cjs",
            "timeout": 15
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "node ~/.claude/hooks/notification-router.cjs",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    }
  },
  "enabledPlugins": {
    "superpowers@anthropic-official": true,
    "code-review@anthropic-official": true,
    "feature-dev@anthropic-official": true,
    "commit@anthropic-official": true,
    "playwright-skill@anthropic-official": true,
    "context7@anthropic-official": true,
    "codex-plugin-cc@third-party-marketplace": true,
    "ECC-AgentShield@third-party-marketplace": true
  }
}
