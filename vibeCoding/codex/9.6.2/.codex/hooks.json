{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/session-start.py",
            "timeout": 10,
            "statusMessage": "Loading Athena context"
          }
        ]
      }
    ],

    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/user-prompt-submit.py",
            "timeout": 5,
            "statusMessage": "Athena pre-check"
          },
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/index-updater.py",
            "timeout": 8,
            "statusMessage": "Syncing _index.md counts"
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/pre-bash-guard.py",
            "timeout": 10,
            "statusMessage": "Checking Bash command"
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/subagent-retry.py",
            "timeout": 10
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/delivery-gate.py",
            "timeout": 60,
            "statusMessage": "Athena delivery-gate"
          }
        ]
      }
    ]
  }
}
