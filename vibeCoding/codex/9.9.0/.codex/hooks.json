{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/session-start.py",
            "timeout": 10,
            "statusMessage": "Loading Athena context"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/user-prompt-submit.py",
            "timeout": 5,
            "statusMessage": "Athena pre-check"
          },
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/index-updater.py",
            "timeout": 8,
            "statusMessage": "Syncing _index.md counts"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/pre-bash-guard.py",
            "timeout": 10,
            "statusMessage": "Checking Bash command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/subagent-retry.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/evidence-collector.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/index-updater.py",
            "timeout": 8,
            "_comment": "v9.9.0: 补挂 — 原只挂 UserPromptSubmit, Goals 长自主 loop 中用户不提交 prompt, re-route 机械触发滞后整个 loop"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/subagent-tracker.py",
            "timeout": 15
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/token-usage-collector.py",
            "timeout": 15,
            "statusMessage": "Collecting subagent token usage"
          },
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/subagent-tracker.py",
            "timeout": 15
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/token-usage-collector.py",
            "timeout": 15,
            "statusMessage": "Collecting token usage"
          },
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/delivery-gate.py",
            "timeout": 60,
            "statusMessage": "Athena delivery-gate"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/compact-snapshot.py",
            "timeout": 15
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 ~/.codex/hooks/compact-restore.py",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
