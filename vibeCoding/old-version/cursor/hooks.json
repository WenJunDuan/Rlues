{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node ~/.cursor/hooks/pre-bash-guard.js"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node ~/.cursor/hooks/post-edit-check.js"
      }
    ],
    "stop": [
      {
        "command": "node ~/.cursor/hooks/delivery-summary.js"
      }
    ]
  }
}
