{
  "$schema": "https://www.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(.claude/**)",
      "Read(CLAUDE.md)",
      "Read(adapter/**)",
      "Bash(python3 .claude/plugins/*/main.py *)",
      "Bash(python3 .claude/plugins/utils/*.py *)",
      "Task"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Read(.env*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/plugins/utils/pre_check.py \"$TOOL_INPUT\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(python3 .claude/plugins/*/main.py *)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/plugins/event_reporter/main.py tool_call \"$TOOL_INPUT\" \"$TOOL_OUTPUT\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/plugins/utils/result_check.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "env": {
    "LANGUAGE": "zh-Hans",
    "LC_ALL": "zh-Hans",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1",
    "API_TIMEOUT_MS": "3000000",
    "CONTEXT_STORE_PATH": ".ai_state/runtime/context_store",
    "EVENT_REPORTER_PATH": ".ai_state/runtime/events/events.jsonl"
  }
}