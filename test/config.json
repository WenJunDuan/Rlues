{
  "version": 1,
  "persistence": {
    "backend": "memory",
    "redis": {
      "event_ttl_seconds": 86400
    }
  },
  "gateway": {
    "auth": {
      "header": "X-Adapter-Key"
    },
    "features": {
      "audit": {
        "command": "/audit",
        "instruction": "review",
        "enabled": true,
        "expose_http": true,
        "scope": "public"
      }
    },
    "endpoints": {
      "health": {
        "enabled": true,
        "scope": "public"
      },
      "feature_submit": {
        "enabled": true,
        "scope": "public"
      },
      "task_query": {
        "enabled": true,
        "scope": "public"
      },
      "task_events": {
        "enabled": true,
        "scope": "public"
      },
      "task_compliance": {
        "enabled": true,
        "scope": "public"
      },
      "feature_query": {
        "enabled": true,
        "scope": "public"
      },
      "feature_events": {
        "enabled": true,
        "scope": "public"
      },
      "feature_compliance": {
        "enabled": true,
        "scope": "public"
      },
      "history_list": {
        "enabled": true,
        "scope": "internal"
      },
      "history_delete": {
        "enabled": true,
        "scope": "internal"
      },
      "logs_list": {
        "enabled": true,
        "scope": "internal"
      },
      "logs_archive": {
        "enabled": true,
        "scope": "internal"
      },
      "runtime_queue": {
        "enabled": true,
        "scope": "internal"
      },
      "runtime_exposure": {
        "enabled": true,
        "scope": "internal"
      }
    }
  },
  "sdk": {
    "_comment": "Legacy fields below are kept for test_gateway_security.py compatibility",
    "setting_sources": ["project"],
    "permission_mode": null,
    "sandbox": true,
    "allowed_tools": ["Read", "Grep", "Glob", "Task"],
    "enable_plugin_bash": false
  }
}
