# ─────────────────────────────────────────────────
# Adapter 全局环境变量配置
# 复制此文件为 .env，填入实际值后使用
# 约定：所有密钥与 URL 仅放在 .env，不放在 config.json
# ─────────────────────────────────────────────────

# ─── Anthropic API ────────────────────────────────
# Anthropic Messages API Key（用于所有审核推理调用）
# 设置为有效 API Key 以启用 Anthropic 云端调用
# 若使用本地兼容端点，可设为 dummy 或留空
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── 本地 LLM 端点（Anthropic Messages API 兼容）──
# 设置后自动走 HTTP 直调，不使用 Anthropic SDK
# 支持 vLLM / Ollama / LiteLLM 等兼容 /v1/messages 的端点
ADAPTER_LLM_BASE_URL=http://localhost:8000
# 本地端点独立 API Key（可选，留空不鉴权）
# ADAPTER_LLM_API_KEY=
# 模型名称（若不设置，默认 claude-sonnet-4-20250514）
ADAPTER_LLM_MODEL=Qwen/Qwen3.5-35B-A3B

# ─── Gateway 鉴权密钥 ─────────────────────────────
# 公开端点 API Key（逗号分隔，支持多个）
# 用于 /api/task, /api/features 等端点的访问鉴权
ADAPTER_PUBLIC_API_KEYS=pk-dev-001
# 内部端点 API Key（逗号分隔，支持多个）
# 用于 /api/history, /api/logs, /api/runtime 等内部管理端点
ADAPTER_INTERNAL_API_KEYS=ik-dev-001

# ─── Redis 连接（URL/密钥）────────────────────────
# 连接地址（当 ADAPTER_STORE_BACKEND=redis 时生效）
ADAPTER_REDIS_URL=redis://127.0.0.1:6379/0
# Redis 连接密码（留空表示不鉴权）
ADAPTER_REDIS_PASSWORD=

# ─── 适配层运行参数（非敏感，可选）────────────────
# 覆写 config.json 路径（默认为项目根 config.json）
# ADAPTER_CONFIG_PATH=./config.json
# 存储后端：memory 或 redis
# ADAPTER_STORE_BACKEND=memory
# Redis 事件保留时长（秒）
# ADAPTER_REDIS_EVENT_TTL=86400
# 日志输出目录（默认为 adapter/logs/）
# ADAPTER_LOG_DIR=./adapter/logs
# 状态文件目录（默认为 adapter/state/）
# ADAPTER_STATE_DIR=./adapter/state

# ─── LLM 高级配置（通常无需修改）──────────────────
# Claude API 超时（秒，默认 120）
# ADAPTER_CLAUDE_TIMEOUT=120
# Claude API 最大重试次数（默认 2）
# ADAPTER_CLAUDE_MAX_RETRIES=2
