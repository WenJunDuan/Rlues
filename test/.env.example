# ─────────────────────────────────────────────────
# Adapter 全局环境变量配置
# 复制此文件为 .env，填入实际值后使用
# 约定：所有密钥与 URL 仅放在 .env，不放在 config.json
# 注意：Claude Code 不一定自动读取 .env；请用你的 shell/direnv/docker-compose 等方式注入环境变量
# ─────────────────────────────────────────────────

# ─── Claude Code 工具链 URL ───────────────────────
# 本地 LLM 网关地址（对应 .claude/settings.json 中的 LOCAL_LLM_BASE_URL）
LOCAL_LLM_BASE_URL=http://localhost:8080/v1

# ─── Claude SDK API Key ───────────────────────────
# claude_agent_sdk 自动从此环境变量读取 API Key
# 必填：用于所有 Claude 调用（审核推理、工具调用等）
ANTHROPIC_API_KEY=sk-ant-xxxxx

# ─── Gateway 鉴权密钥 ─────────────────────────────
# 公开端点 API Key（逗号分隔，支持多个）
# 用于 /api/task, /api/features 等端点的访问鉴权
ADAPTER_PUBLIC_API_KEYS=pk-dev-001
# 内部端点 API Key（逗号分隔，支持多个）
# 用于 /api/history, /api/logs, /api/runtime 等内部管理端点
ADAPTER_INTERNAL_API_KEYS=ik-dev-001

# ─── Redis 连接（URL/密钥）────────────────────────
# 连接地址（当 ADAPTER_STORE_BACKEND=redis 时生效）
ADAPTER_REDIS_URL=redis://127.0.0.1:6379/0
# Redis 连接密码（留空表示不鉴权）
ADAPTER_REDIS_PASSWORD=

# ─── 插件外部服务（URL/密钥）──────────────────────
# 税务 API（tax_api 插件使用，预留对接）
TAX_API_URL=https://tax-api.example.com/v1/verify
TAX_API_KEY=tax-api-key-xxxxx

# ─── 适配层运行参数（非敏感，可选）────────────────
# 覆写 config.json 路径（默认为项目根 config.json）
# ADAPTER_CONFIG_PATH=./config.json
# 存储后端：memory 或 redis
# ADAPTER_STORE_BACKEND=memory
# Redis 事件保留时长（秒）
# ADAPTER_REDIS_EVENT_TTL=86400
# 事件告警回调 URL（可选）
# ADAPTER_NOTIFICATION_URL=https://notify.example.com/webhook
# 日志输出目录（默认为 adapter/logs/）
# ADAPTER_LOG_DIR=./adapter/logs
# 状态文件目录（默认为 adapter/state/）
# ADAPTER_STATE_DIR=./adapter/state
# init_dev_keys 自定义 .env 路径（可选）
# ADAPTER_ENV_PATH=./.env

# ─── SDK 高级配置（通常无需修改，非密钥）──────────
# Claude SDK setting sources（逗号分隔）
# ADAPTER_SDK_SETTING_SOURCES=project
# Claude SDK permission mode
# ADAPTER_SDK_PERMISSION_MODE=
# 是否启用 SDK Sandbox
# ADAPTER_SDK_SANDBOX=true
# SDK 允许使用的工具（逗号分隔）
# ADAPTER_SDK_ALLOWED_TOOLS=Read,Grep,Glob,Task
# 是否允许 SDK 通过 Bash 调用插件
# ADAPTER_SDK_ENABLE_PLUGIN_BASH=false
